FROM golang:1.25-alpine AS build

WORKDIR /src
RUN apk add --no-cache git ca-certificates
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/secondbrain ./cmd/api

FROM alpine:3.21

RUN addgroup -S app && adduser -S app -G app
WORKDIR /app
COPY --from=build /bin/secondbrain /app/secondbrain
COPY configs /app/configs
COPY migrations /app/migrations
USER app

EXPOSE 8080
ENTRYPOINT ["/app/secondbrain"]
